<Window x:Class="QwertyStock.Bootstrapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QwertyStock"
        MinHeight="580"
        Height="580"
        Width="420"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/app.ico"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">
  <Grid SnapsToDevicePixels="True">
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF27A23" Offset="0" />
        <GradientStop Color="#FFE0452E" Offset="0.45" />
        <GradientStop Color="#FFC41E1E" Offset="0.72" />
        <GradientStop Color="#FF8B1530" Offset="1" />
      </LinearGradientBrush>
    </Grid.Background>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Title -->
    <Grid Grid.Row="0" Margin="18,16,12,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel VerticalAlignment="Center">
        <TextBlock x:Name="BrandLine1"
                   Text="QWERTYSTOCK"
                   FontSize="21"
                   FontWeight="Bold"
                   Foreground="White"
                   FontFamily="Segoe UI" />
        <TextBlock x:Name="BrandLine2"
                   Text="NEXT GEN MICROSTOCK"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="#F0FFFFFF"
                   Margin="0,4,0,0"
                   FontFamily="Segoe UI" />
        <TextBlock x:Name="TaglineText"
                   FontSize="12"
                   Foreground="#E6FFFFFF"
                   Margin="0,6,0,0"
                   TextWrapping="Wrap"
                   FontFamily="Segoe UI" />
      </StackPanel>
      <Button x:Name="CloseButton"
              Grid.Column="1"
              Width="32"
              Height="32"
              Padding="0"
              FontSize="14"
              Foreground="White"
              Background="#35FFFFFF"
              BorderThickness="0"
              Cursor="Hand"
              Click="CloseButton_Click"
              ToolTip="Close">
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="0">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Button.Template>
        ✕
      </Button>
    </Grid>

    <Grid Grid.Row="1"
          Margin="18,14,18,16">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="200" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" MinHeight="44" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Dark glass panel -->
      <Border Grid.Row="0"
              Background="#D8181E28"
              BorderBrush="#33FFFFFF"
              BorderThickness="1"
              Padding="18,16,18,16"
              VerticalAlignment="Stretch">
        <StackPanel VerticalAlignment="Center">
          <Image Width="160"
                 Height="160"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"
                 RenderOptions.BitmapScalingMode="HighQuality"
                 Source="pack://application:,,,/Assets/SplashLogo.png" />

          <TextBlock x:Name="IntroText"
                     Margin="0,14,0,0"
                     Foreground="#E8EDF3"
                     FontSize="14"
                     LineHeight="22"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     FontFamily="Segoe UI"
                     Text="" />

          <TextBlock x:Name="WhySlowText"
                     Margin="0,12,0,0"
                     Foreground="#9AA3B2"
                     FontSize="11.5"
                     LineHeight="17"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     FontFamily="Segoe UI"
                     Text="" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Margin="0,14,0,0"
              BorderBrush="#55FFFFFF"
              BorderThickness="1"
              Background="#30000000"
              Padding="2"
              SnapsToDevicePixels="True">
        <ProgressBar x:Name="ProgressBar"
                     Height="16"
                     Minimum="0"
                     Maximum="100"
                     Value="0"
                     Foreground="#FFFFE49E"
                     Background="#38FFFFFF" />
      </Border>

      <TextBlock x:Name="StatusText"
                 Grid.Row="2"
                 Margin="0,10,0,2"
                 Foreground="#FFFFFF"
                 TextWrapping="Wrap"
                 FontSize="13.5"
                 LineHeight="20"
                 VerticalAlignment="Top"
                 FontFamily="Segoe UI"
                 Text="" />

      <TextBlock x:Name="DetailText"
                 Grid.Row="3"
                 Margin="0,0,0,4"
                 Foreground="#C5D0DC"
                 TextWrapping="Wrap"
                 FontSize="11"
                 LineHeight="16"
                 MaxHeight="72"
                 VerticalAlignment="Top"
                 FontFamily="Consolas"
                 Visibility="Collapsed"
                 Text="" />

      <TextBlock x:Name="VersionText"
                 Grid.Row="4"
                 HorizontalAlignment="Right"
                 Margin="0,4,0,0"
                 FontSize="11"
                 FontFamily="Segoe UI"
                 Foreground="#B3FFFFFF"
                 IsHitTestVisible="False"
                 Text="" />
    </Grid>
  </Grid>
</Window>
