<Window x:Class="QwertyStock.Bootstrapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QwertyStock"
        Height="500"
        Width="420"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/app.ico">
  <Border CornerRadius="14"
          BorderBrush="#4DFFFFFF"
          BorderThickness="1"
          Padding="0">
    <Border.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF27A23" Offset="0" />
        <GradientStop Color="#FFC41E1E" Offset="0.55" />
        <GradientStop Color="#FF8B1530" Offset="1" />
      </LinearGradientBrush>
    </Border.Background>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Grid Grid.Row="0"
            Margin="16,12,8,0"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="QWERTYSTOCK"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="White"
                     FontFamily="Segoe UI" />
          <TextBlock Text="Локальный веб-интерфейс"
                     FontSize="12.5"
                     Foreground="#E6FFFFFF"
                     Margin="0,2,0,0"
                     FontFamily="Segoe UI" />
        </StackPanel>
        <Button Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                FontSize="14"
                Foreground="White"
                Background="#33FFFFFF"
                BorderThickness="0"
                Cursor="Hand"
                Click="CloseButton_Click"
                ToolTip="Закрыть">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}"
                      CornerRadius="6">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Button.Template>
          ✕
        </Button>
      </Grid>

      <!-- Content -->
      <StackPanel Grid.Row="1"
                  Margin="24,16,24,24">
        <Border Background="#2E000000"
                CornerRadius="12"
                Padding="16"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">
          <StackPanel>
            <Image x:Name="LogoImage"
                   Width="200"
                   Height="200"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <TextBlock x:Name="IntroText"
                       Margin="0,18,0,0"
                       Foreground="#F5FFFFFF"
                       FontSize="13"
                       LineHeight="20"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontFamily="Segoe UI"
                       Text="Сейчас будет установлено окружение: встроенный Python, portable Git, синхронизация репозитория и зависимостей. После этого откроется браузер на http://localhost:3000 — это ваш локальный кабинет QwertyStock." />
          </StackPanel>
        </Border>

        <ProgressBar x:Name="ProgressBar"
                     Height="10"
                     Margin="0,20,0,0"
                     Minimum="0"
                     Maximum="100"
                     Value="0"
                     Foreground="#FFFFE49E"
                     Background="#40FFFFFF" />

        <TextBlock x:Name="StatusText"
                   Margin="0,14,0,0"
                   Foreground="White"
                   TextWrapping="Wrap"
                   FontSize="13.5"
                   LineHeight="19"
                   FontFamily="Segoe UI"
                   Text="Запуск…" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
