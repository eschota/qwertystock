<Window x:Class="QwertyStock.Bootstrapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QwertyStock"
        Height="500"
        Width="420"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/app.ico"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">
  <Border CornerRadius="14"
          BorderBrush="#59FFFFFF"
          BorderThickness="1"
          Padding="0">
    <Border.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF27A23" Offset="0" />
        <GradientStop Color="#FFE0452E" Offset="0.45" />
        <GradientStop Color="#FFC41E1E" Offset="0.72" />
        <GradientStop Color="#FF8B1530" Offset="1" />
      </LinearGradientBrush>
    </Border.Background>
    <Border.Effect>
      <DropShadowEffect BlurRadius="22"
                        ShadowDepth="0"
                        Opacity="0.42"
                        Color="#FF2A0A0A" />
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Title -->
      <Grid Grid.Row="0" Margin="18,14,10,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="QWERTYSTOCK"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="White"
                     FontFamily="Segoe UI" />
          <TextBlock Text="Локальный веб-интерфейс"
                     FontSize="12.5"
                     Foreground="#E6FFFFFF"
                     Margin="0,2,0,0"
                     FontFamily="Segoe UI" />
        </StackPanel>
        <Button x:Name="CloseButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                FontSize="14"
                Foreground="White"
                Background="#40FFFFFF"
                BorderThickness="0"
                Cursor="Hand"
                Click="CloseButton_Click"
                ToolTip="Закрыть">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}"
                      CornerRadius="6">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Button.Template>
          ✕
        </Button>
      </Grid>

      <!-- Body -->
      <Grid Grid.Row="1" Margin="22,14,22,20">
        <StackPanel>
          <Border Background="#1AFFFFFF"
                  CornerRadius="14"
                  Padding="18,16,18,20"
                  BorderBrush="#40FFFFFF"
                  BorderThickness="1">
            <Border.Effect>
              <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.2" Color="#FF000000" />
            </Border.Effect>
            <StackPanel>
              <Image x:Name="LogoImage"
                     Width="200"
                     Height="200"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     RenderOptions.BitmapScalingMode="HighQuality" />

              <TextBlock x:Name="IntroText"
                         Margin="0,16,0,0"
                         Foreground="#F8FFFFFF"
                         FontSize="13"
                         LineHeight="20"
                         TextWrapping="Wrap"
                         TextAlignment="Center"
                         FontFamily="Segoe UI"
                         Text="Сейчас будет установлено окружение: встроенный Python, portable Git, синхронизация репозитория и зависимостей. После этого откроется браузер на http://localhost:3000 — это ваш локальный кабинет QwertyStock." />
            </StackPanel>
          </Border>

          <ProgressBar x:Name="ProgressBar"
                       Height="10"
                       Margin="0,18,0,0"
                       Minimum="0"
                       Maximum="100"
                       Value="0"
                       Foreground="#FFFFE49E"
                       Background="#38FFFFFF" />

          <TextBlock x:Name="StatusText"
                     Margin="0,12,0,0"
                     Foreground="White"
                     TextWrapping="Wrap"
                     FontSize="13.5"
                     LineHeight="19"
                     FontFamily="Segoe UI"
                     Text="Запуск…" />
        </StackPanel>

        <!-- Version: corner, no hit-test so drag works through label -->
        <TextBlock x:Name="VersionText"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Right"
                   Margin="0,0,2,2"
                   FontSize="11"
                   FontFamily="Segoe UI"
                   Foreground="#8CFFFFFF"
                   IsHitTestVisible="False"
                   Text="v—" />
      </Grid>
    </Grid>
  </Border>
</Window>
