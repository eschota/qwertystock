<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>qwertystock</AssemblyName>
    <RootNamespace>QwertyStock.Bootstrapper</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>QwertyStock</Authors>
    <Product>QwertyStock Bootstrapper</Product>
    <Description>Windows installer / launcher for QwertyStock local web server</Description>
  </PropertyGroup>
  <ItemGroup>
    <Resource Include="Assets\QS_LOGO.gif" />
  </ItemGroup>
</Project>
